---
import type { MetaEntry } from '../content/docs/_meta'

export interface Props {
  title: string
  description?: string
  sidebar: MetaEntry[]
  headings?: { depth: number; slug: string; text: string }[]
}

const { title, description, sidebar, headings = [] } = Astro.props

function renderSidebar(entries: MetaEntry[]) {
  return entries.map((entry) => {
    if ('items' in entry) {
      return `
        <div class="sidebar-group">
          <div class="sidebar-group-title" data-group="${entry.label}">
            ${entry.label}
            <svg class="sidebar-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </div>
          <div class="sidebar-items" id="group-${entry.label}">
            ${entry.items.map((item) => `
              <a href="/docs/${item.slug}" class="sidebar-item">${item.label}</a>
            `).join('')}
          </div>
        </div>`
    }
    return `
      <div class="sidebar-group">
        <a href="/docs/${entry.slug}" class="sidebar-item" style="font-weight:500">${entry.label}</a>
      </div>`
  }).join('')
}
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Sage</title>
    {description && <meta name="description" content={description} />}

    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <style is:global>
      :root {
        --color-bg: #fff; --color-fg: #171717; --color-muted: #737373;
        --color-border: #e5e5e5; --color-accent: #7c3aed; --color-accent-light: #f5f3ff;
        --color-surface: #fafafa; --color-nav-bg: rgba(255,255,255,0.88);
        --color-code-bg: #f5f5f5; --color-overlay: rgba(0,0,0,0.35);
        --color-bg-rgb: 255,255,255; --color-fg-rgb: 23,23,23;
      }
      [data-theme="dark"] {
        --color-bg: #0d0d0d; --color-fg: #ededed; --color-muted: #888;
        --color-border: #2a2a2a; --color-accent: #a78bfa; --color-accent-light: rgba(139,92,246,0.12);
        --color-surface: #171717; --color-nav-bg: rgba(13,13,13,0.88);
        --color-code-bg: #1e1e1e; --color-overlay: rgba(0,0,0,0.6);
        --color-bg-rgb: 13,13,13; --color-fg-rgb: 237,237,237;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; overflow-x: hidden; }
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--color-bg); color: var(--color-fg);
        line-height: 1.7; min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      a { color: var(--color-accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* ── Navbar ── */
      .navbar {
        position: sticky; top: 0; z-index: 50;
        border-bottom: 1px solid rgba(229,229,229,0.7);
        background: var(--color-nav-bg);
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        height: 3.5rem;
      }
      .navbar-inner {
        display: flex; align-items: center; gap: 0.75rem;
        max-width: 90rem; margin: 0 auto; height: 100%; padding: 0 1.25rem;
      }
      .navbar-logo {
        display: flex; align-items: center; gap: 0.5rem;
        font-weight: 700; font-size: 1rem; color: var(--color-fg); text-decoration: none;
        flex-shrink: 0; margin-right: auto;
      }
      .navbar-logo-icon {
        display: flex; align-items: center; justify-content: center;
        width: 1.75rem; height: 1.75rem; border-radius: 0.5rem;
        background: var(--color-accent); color: #fff; font-size: 0.75rem; font-weight: 700;
      }

      .navbar-links { display: flex; align-items: center; gap: 0.125rem; flex-shrink: 0; }
      .navbar-link {
        display: inline-flex; align-items: center; gap: 0.35rem;
        padding: 0.4rem 0.75rem; border-radius: 0.5rem;
        font-size: 0.875rem; color: var(--color-muted);
        transition: background 0.15s, color 0.15s;
        background: none; border: none; cursor: pointer; font-family: inherit;
        white-space: nowrap;
      }
      .navbar-link:hover { background: var(--color-code-bg); color: var(--color-fg); text-decoration: none; }
      .navbar-link.active { background: var(--color-accent-light); color: var(--color-accent); }

      .nav-spacer { flex: 1; }

      .hamburger {
        display: none; background: none; border: none; cursor: pointer;
        padding: 0.4rem; border-radius: 0.5rem; color: var(--color-muted);
        flex-shrink: 0;
      }
      .hamburger:hover { background: var(--color-code-bg); color: var(--color-fg); }

      /* ── Sidebar Overlay (mobile) ── */
      .sidebar-overlay {
        display: none;
        position: fixed; inset: 0; z-index: 45;
        background: var(--color-overlay);
      }

      @media (max-width: 768px) {
        .hamburger { display: flex; }
        .sidebar {
          position: fixed !important; top: 3.5rem !important; left: 0; bottom: 0;
          z-index: 46; background: #fff;
          transform: translateX(-100%); transition: transform 0.25s ease;
          width: 17rem !important; height: auto !important;
          box-shadow: 2px 0 12px rgba(0,0,0,0.08);
        }
        .sidebar.open { transform: translateX(0); }
        .sidebar-overlay.open { display: block; }

        .content { padding: 1.5rem 1rem !important; }
        .content h1 { font-size: 1.6rem !important; }
        .content h2 { font-size: 1.25rem !important; }
        .content h3 { font-size: 1.05rem !important; }
      }
      @media (min-width: 769px) {
        .sidebar-overlay { display: none !important; }
      }

      /* ── Layout ── */
      .docs-container { display: flex; max-width: 90rem; margin: 0 auto; }

      /* ── Sidebar ── */
      .sidebar {
        position: sticky; top: 3.5rem; width: 15rem; flex-shrink: 0;
        height: calc(100vh - 3.5rem); overflow-y: auto;
        border-right: 1px solid rgba(229,229,229,0.7); padding: 1.5rem 1rem;
      }
      .sidebar::-webkit-scrollbar { width: 4px; }
      .sidebar::-webkit-scrollbar-thumb { background: #d4d4d4; border-radius: 9999px; }
      .sidebar-group { margin-bottom: 1rem; }
      .sidebar-group-title {
        display: flex; align-items: center; justify-content: space-between;
        font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.06em; color: var(--color-muted);
        padding: 0.4rem 0.5rem; cursor: pointer; border-radius: 0.5rem;
        transition: color 0.15s; width: 100%; background: none; border: none;
        font-family: inherit;
      }
      .sidebar-group-title:hover { color: var(--color-fg); }
      .sidebar-toggle-icon { width: 13px; height: 13px; transition: transform 0.2s; flex-shrink: 0; }
      .sidebar-toggle-icon.collapsed { transform: rotate(-90deg); }
      .sidebar-items { display: flex; flex-direction: column; gap: 0.125rem; }
      .sidebar-items.hidden { display: none; }
      .sidebar-item {
        display: block; padding: 0.4rem 0.625rem; border-radius: 0.5rem;
        font-size: 0.875rem; color: var(--color-muted);
        transition: background 0.15s, color 0.15s; line-height: 1.5;
        text-decoration: none;
      }
      .sidebar-item:hover { background: #f5f5f5; color: var(--color-fg); text-decoration: none; }
      .sidebar-item.active { background: var(--color-accent-light); color: var(--color-accent); font-weight: 500; }

      /* ── Content ── */
      .content { flex: 1; min-width: 0; padding: 2.5rem 3rem; max-width: 50rem; }
      .content h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.35rem; letter-spacing: -0.02em; line-height: 1.3; }
      .content h2 { font-size: 1.5rem; font-weight: 600; margin-top: 2.5rem; margin-bottom: 0.75rem; scroll-margin-top: 4rem; letter-spacing: -0.01em; }
      .content h3 { font-size: 1.2rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.5rem; scroll-margin-top: 4rem; }
      .content p { margin-bottom: 1rem; word-break: break-word; }
      .content ul, .content ol { margin: 1rem 0; padding-left: 1.5rem; }
      .content li { margin-bottom: 0.35rem; }
      .content strong { font-weight: 600; }

      .content pre {
        overflow-x: auto; border-radius: 0.75rem;
        border: 1px solid var(--color-border); background: var(--color-surface);
        padding: 1rem 1.25rem; margin: 1rem 0; font-size: 0.85rem; line-height: 1.65;
        -webkit-overflow-scrolling: touch;
      }
      .content code { font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace; font-size: 0.875em; }
      .content :not(pre) > code {
        background: #f5f5f5; color: var(--color-accent);
        padding: 0.15rem 0.4rem; border-radius: 0.35rem; font-weight: 500;
        word-break: break-all;
      }
      .content table {
        width: 100%; font-size: 0.875rem; border-collapse: collapse;
        margin: 1rem 0; border-radius: 0.5rem; overflow: hidden; border: 1px solid var(--color-border);
        display: block; overflow-x: auto; -webkit-overflow-scrolling: touch;
      }
      .content th { background: var(--color-surface); font-weight: 600; text-align: left; padding: 0.6rem 1rem; border-bottom: 1px solid var(--color-border); white-space: nowrap; }
      .content td { padding: 0.6rem 1rem; border-bottom: 1px solid #f5f5f5; }
      .content tr:last-child td { border-bottom: none; }
      .content blockquote {
        border-left: 4px solid #c4b5fd; background: rgba(245,243,255,0.5);
        padding: 0.5rem 1rem; margin: 1rem 0; border-radius: 0 0.5rem 0.5rem 0;
        color: var(--color-muted); font-style: italic;
      }
      .content hr { border: none; border-top: 1px solid var(--color-border); margin: 2.5rem 0; }
      .content img { max-width: 100%; border-radius: 0.5rem; height: auto; }
      .content-description { font-size: 1.1rem; color: var(--color-muted); margin-bottom: 2rem; line-height: 1.6; }

      @media (max-width: 1024px) {
        .content { padding: 2rem 1.5rem; }
      }

      /* ── ToC ── */
      .toc {
        position: sticky; top: 3.5rem; width: 13rem; flex-shrink: 0;
        height: calc(100vh - 3.5rem); overflow-y: auto;
        padding: 1.5rem 0.75rem 1.5rem 0; font-size: 0.8rem; display: none;
      }
      @media (min-width: 1280px) { .toc { display: block; } }
      .toc-title {
        font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.06em; color: var(--color-muted); margin-bottom: 0.75rem;
        padding-left: 0.75rem;
      }
      .toc-link {
        display: block; padding: 0.35rem 0; color: var(--color-muted);
        border-left: 2px solid transparent; padding-left: 0.75rem;
        transition: color 0.15s, border-color 0.15s; line-height: 1.4;
        text-decoration: none; font-size: 0.8rem;
      }
      .toc-link:hover { color: var(--color-fg); text-decoration: none; }
      .toc-link.active { color: var(--color-accent); font-weight: 500; border-left-color: var(--color-accent); }
      .toc-link.level-3 { padding-left: 1.5rem; }

      /* ── Search Dialog ── */
      #search-overlay { display: none; position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.35); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); }
      #search-dialog {
        display: none; position: fixed; top: 15%; left: 50%; transform: translateX(-50%);
        z-index: 101; width: calc(100vw - 2rem); max-width: 520px;
        background: #fff; border-radius: 0.85rem;
        box-shadow: 0 20px 60px rgba(0,0,0,0.15); overflow: hidden;
      }
      @media (max-width: 640px) {
        #search-dialog { top: 5%; max-height: 80vh; display: none; }
        #search-dialog.open-dialog { display: flex; flex-direction: column; }
        #search-results { flex: 1; overflow-y: auto; }
      }
      .search-header {
        display: flex; align-items: center; padding: 0.75rem 1rem;
        border-bottom: 1px solid #e5e5e5; gap: 0.5rem;
      }
      .search-header svg { flex-shrink: 0; }
      .search-header input {
        flex: 1; border: none; outline: none; font-size: 1rem;
        padding: 0.25rem 0.5rem; font-family: inherit; background: transparent;
      }
      .search-close-btn {
        background: none; border: none; cursor: pointer;
        padding: 0.25rem 0.5rem; color: #737373; font-size: 1.25rem;
        line-height: 1; border-radius: 0.35rem;
      }
      .search-close-btn:hover { background: #f5f5f5; }
      .search-result-item {
        display: block; padding: 0.75rem 1rem; border-bottom: 1px solid #f0f0f0;
        color: inherit; text-decoration: none; transition: background 0.1s;
      }
      .search-result-item:hover, .search-result-item:focus { background: #f9f9f9; text-decoration: none; }
      .search-result-title { font-weight: 600; margin-bottom: 0.15rem; font-size: 0.875rem; }
      .search-result-excerpt { font-size: 0.8rem; color: #737373; line-height: 1.5; }
      .search-empty-state { display: none; padding: 2.5rem 1rem; text-align: center; color: var(--color-muted); font-size: 0.875rem; }

      /* Dark mode overrides */
      [data-theme="dark"] .sidebar { background: var(--color-bg); }
      [data-theme="dark"] .sidebar-item:hover { background: #1e1e1e; }
      [data-theme="dark"] .sidebar-item.active { background: rgba(139,92,246,0.15); }
      [data-theme="dark"] .navbar-link:hover { background: #1e1e1e; }
      [data-theme="dark"] .navbar-link.active { background: rgba(139,92,246,0.15); }
      [data-theme="dark"] .hamburger:hover { background: #1e1e1e; }
      [data-theme="dark"] #search-dialog { background: #171717; border: 1px solid #2a2a2a; }
      [data-theme="dark"] .search-header { border-color: #2a2a2a; }
      [data-theme="dark"] .search-header input { color: var(--color-fg); }
      [data-theme="dark"] .search-header input::placeholder { color: #555; }
      [data-theme="dark"] .search-result-item { border-color: #2a2a2a; }
      [data-theme="dark"] .search-result-item:hover { background: #1e1e1e; }
      [data-theme="dark"] .search-close-btn:hover { background: #2a2a2a; }
      [data-theme="dark"] .content :not(pre) > code { background: #1e1e1e; color: var(--color-accent); }
      [data-theme="dark"] .content blockquote { background: rgba(139,92,246,0.08); border-color: #5b3ea8; }
      [data-theme="dark"] .content th { background: #1a1a1a; }
      [data-theme="dark"] .content td { border-color: #1e1e1e; }
      [data-theme="dark"] .content pre { background: #111; border-color: #2a2a2a; }
      [data-theme="dark"] .toc-link:hover { color: var(--color-fg); }
      [data-theme="dark"] img { opacity: 0.85; }
    </style>
  </head>
  <body>
    <!-- Navbar -->
    <header class="navbar">
      <div class="navbar-inner">
        <a href="/" class="navbar-logo">
          <span class="navbar-logo-icon">S</span> Sage
        </a>
        <button class="hamburger" id="hamburger" aria-label="菜单">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/>
          </svg>
        </button>
        <nav class="navbar-links" id="navbar-links">
          <button class="navbar-link" id="search-btn" style="cursor:pointer;background:none;border:none;font-family:inherit;font-size:0.875rem">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:0.35rem"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            搜索
          </button>
          <a href="https://github.com/Mineocean/TestWiki" target="_blank" rel="noreferrer" class="navbar-link" style="padding:0.375rem" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
          </a>
          <button class="navbar-link" id="theme-toggle" style="padding:0.375rem;background:none;border:none;cursor:pointer;font-family:inherit" aria-label="切换主题">
            <svg id="theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            <svg id="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </nav>
      </div>
    </header>

    <!-- Sidebar overlay for mobile -->
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <div class="docs-container">
      <!-- Sidebar -->
      <aside class="sidebar" id="sidebar">
        <nav>
          <div class="sidebar-group">
            <a href="/" class="sidebar-item" style="font-weight:600">← 首页</a>
          </div>
          <Fragment set:html={renderSidebar(sidebar)} />
        </nav>
      </aside>

      <!-- Content -->
      <main class="content" id="content">
        <h1>{title}</h1>
        {description && <p class="content-description">{description}</p>}
        <slot />
      </main>

      <!-- ToC -->
      <aside class="toc">
        <div class="toc-title">本页目录</div>
        <nav id="toc-nav">
          {headings.length > 0 && headings.map((h) => (
            <a
              href={`#${h.slug}`}
              class={`toc-link${h.depth === 3 ? ' level-3' : ''}`}
              data-heading={h.slug}
            >
              {h.text}
            </a>
          ))}
        </nav>
      </aside>
    </div>

    <!-- Search dialog -->
    <div id="search-overlay"></div>
    <div id="search-dialog">
      <div class="search-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#737373" stroke-width="2" style="flex-shrink:0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input id="search-input" type="text" placeholder="搜索文档..." />
        <button class="search-close-btn" id="search-close" aria-label="关闭">&times;</button>
      </div>
      <div id="search-results" style="max-height:400px;overflow-y:auto"></div>
      <div class="search-empty-state" id="search-empty">未找到结果</div>
    </div>

    <script is:inline src="/pagefind/pagefind.js"></script>

    <script>
      // ── Theme ──
      (function() {
        const saved = localStorage.getItem('theme');
        const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        const theme = saved || prefers;
        document.documentElement.setAttribute('data-theme', theme);
        if (theme === 'dark') {
          document.getElementById('theme-icon-sun').style.display = 'none';
          document.getElementById('theme-icon-moon').style.display = 'block';
        }
      })();

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        document.getElementById('theme-icon-sun').style.display = next === 'dark' ? 'none' : 'block';
        document.getElementById('theme-icon-moon').style.display = next === 'dark' ? 'block' : 'none';
      });

      // ── Active sidebar & navbar ──
      const path = location.pathname.replace(/\/$/, '').replace('/index.html', '') || '/';
      document.querySelectorAll('.sidebar-item').forEach(el => {
        const href = el.getAttribute('href');
        if (href && (path === href || path === href + '/' || path.startsWith(href + '/'))) {
          el.classList.add('active');
        }
      });
      document.querySelectorAll('.navbar-link').forEach(el => {
        const href = el.getAttribute('href');
        if (href && path.startsWith(href)) el.classList.add('active');
      });

      // ── Mobile sidebar toggle ──
      const sidebar = document.getElementById('sidebar');
      const sidebarOverlay = document.getElementById('sidebar-overlay');

      function openSidebar() {
        sidebar?.classList.add('open');
        sidebarOverlay?.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function closeSidebar() {
        sidebar?.classList.remove('open');
        sidebarOverlay?.classList.remove('open');
        document.body.style.overflow = '';
      }

      document.getElementById('hamburger')?.addEventListener('click', () => {
        sidebar?.classList.contains('open') ? closeSidebar() : openSidebar();
      });
      sidebarOverlay?.addEventListener('click', closeSidebar);

      // ── Collapsible sidebar groups ──
      document.querySelectorAll('.sidebar-group-title').forEach(title => {
        title.addEventListener('click', () => {
          const groupId = title.dataset.group;
          const items = document.getElementById('group-' + groupId);
          const icon = title.querySelector('.sidebar-toggle-icon');
          items?.classList.toggle('hidden');
          icon?.classList.toggle('collapsed');
        });
      });

      // ── ToC scroll spy ──
      (function() {
        const tocLinks = Array.from(document.querySelectorAll('.toc-link'));
        if (tocLinks.length === 0) return;
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              tocLinks.forEach(t => t.classList.remove('active'));
              const active = tocLinks.find(t => t.dataset.heading === entry.target.id);
              active?.classList.add('active');
            }
          });
        }, { rootMargin: '-80px 0px -75% 0px' });
        tocLinks.forEach(t => {
          const el = document.getElementById(t.dataset.heading || '');
          if (el) observer.observe(el);
        });
      })();

      // ── Search ──
      const searchOverlay = document.getElementById('search-overlay');
      const searchDialog = document.getElementById('search-dialog');
      const searchInput = document.getElementById('search-input');
      const searchResults = document.getElementById('search-results');
      const searchEmpty = document.getElementById('search-empty');

      function openSearch() {
        searchOverlay.style.display = 'block';
        searchDialog.style.display = 'block';
        searchInput.focus();
        document.body.style.overflow = 'hidden';
      }

      function closeSearch() {
        searchOverlay.style.display = 'none';
        searchDialog.style.display = 'none';
        searchInput.value = '';
        searchResults.innerHTML = '';
        searchEmpty.style.display = 'none';
        document.body.style.overflow = '';
      }

      document.getElementById('search-btn')?.addEventListener('click', openSearch);
      document.getElementById('search-close')?.addEventListener('click', closeSearch);
      searchOverlay?.addEventListener('click', closeSearch);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
          e.preventDefault();
          openSearch();
        }
        if (e.key === 'Escape') closeSearch();
      });

      let pagefindInstance = null;

      searchInput.addEventListener('input', async function() {
        const query = this.value.trim();
        if (!query) {
          searchResults.innerHTML = '';
          searchEmpty.style.display = 'none';
          return;
        }
        try {
          if (!pagefindInstance && typeof Pagefind !== 'undefined') {
            pagefindInstance = Pagefind;
          }
          if (!pagefindInstance) {
            searchResults.innerHTML = '<div style="padding:2rem;text-align:center;color:#737373">搜索组件加载中...</div>';
            return;
          }
          const search = await pagefindInstance.search(query);
          if (!search || !search.results || search.results.length === 0) {
            searchResults.innerHTML = '';
            searchEmpty.style.display = 'block';
            return;
          }
          searchEmpty.style.display = 'none';
          const results = await Promise.all(search.results.slice(0, 8).map(r => r.data()));
          searchResults.innerHTML = results.map(r => `
            <a href="${(r.url||'').replace(/\.html$/, '').replace(/\/index$/, '')}" class="search-result-item">
              <div class="search-result-title">${r.meta.title}</div>
              <div class="search-result-excerpt">${r.excerpt || ''}</div>
            </a>
          `).join('');
        } catch(e) {
          console.warn('Search error:', e);
        }
      });
    </script>
  </body>
</html>
