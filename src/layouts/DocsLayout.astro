---
import type { MetaEntry } from '../content/docs/_meta'

export interface Props {
  title: string
  description?: string
  sidebar: MetaEntry[]
  headings?: { depth: number; slug: string; text: string }[]
}

const { title, description, sidebar, headings = [] } = Astro.props

function renderSidebar(entries: MetaEntry[]) {
  return entries.map((entry) => {
    if ('items' in entry) {
      return `
        <div class="sidebar-group">
          <div class="sidebar-group-title" data-group="${entry.label}">
            ${entry.label}
            <svg class="sidebar-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </div>
          <div class="sidebar-items" id="group-${entry.label}">
            ${entry.items.map((item) => `
              <a href="/docs/${item.slug}" class="sidebar-item">${item.label}</a>
            `).join('')}
          </div>
        </div>`
    }
    return `
      <div class="sidebar-group">
        <a href="/docs/${entry.slug}" class="sidebar-item" style="font-weight:500">${entry.label}</a>
      </div>`
  }).join('')
}
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Markdown Wiki</title>
    {description && <meta name="description" content={description} />}

    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <style is:global>
      :root {
        --color-bg: #fff; --color-fg: #171717; --color-muted: #737373;
        --color-border: #e5e5e5; --color-accent: #7c3aed; --color-accent-light: #f5f3ff;
        --color-surface: #fafafa;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--color-bg); color: var(--color-fg);
        line-height: 1.7; min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--color-accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* Navbar */
      .navbar {
        position: sticky; top: 0; z-index: 50;
        border-bottom: 1px solid rgba(229,229,229,0.7);
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        height: 3.5rem;
      }
      .navbar-inner {
        display: flex; align-items: center; justify-content: space-between;
        max-width: 90rem; margin: 0 auto; height: 100%; padding: 0 1.25rem;
      }
      .navbar-logo {
        display: flex; align-items: center; gap: 0.5rem;
        font-weight: 700; font-size: 1rem; color: var(--color-fg); text-decoration: none;
      }
      .navbar-logo-icon {
        display: flex; align-items: center; justify-content: center;
        width: 1.75rem; height: 1.75rem; border-radius: 0.5rem;
        background: var(--color-accent); color: #fff; font-size: 0.75rem; font-weight: 700;
      }
      .navbar-links { display: flex; align-items: center; gap: 0.25rem; }
      .navbar-link {
        display: inline-flex; align-items: center;
        padding: 0.375rem 0.75rem; border-radius: 0.5rem;
        font-size: 0.875rem; color: var(--color-muted);
        transition: background 0.15s, color 0.15s;
      }
      .navbar-link:hover { background: #f5f5f5; color: var(--color-fg); text-decoration: none; }
      .navbar-link.active { background: var(--color-accent-light); color: var(--color-accent); }

      .hamburger {
        display: none; background: none; border: none; cursor: pointer;
        padding: 0.375rem; border-radius: 0.5rem; color: var(--color-muted);
      }
      .hamburger:hover { background: #f5f5f5; color: var(--color-fg); }
      @media (max-width: 768px) {
        .hamburger { display: flex; }
        .navbar-links { display: none; }
        .navbar-links.open {
          display: flex; flex-direction: column; position: absolute;
          top: 3.5rem; left: 0; right: 0; background: #fff;
          border-bottom: 1px solid var(--color-border); padding: 0.5rem 1rem; gap: 0;
        }
        .navbar-links.open .navbar-link { width: 100%; padding: 0.5rem 0.75rem; }
      }

      /* Layout */
      .docs-container { display: flex; max-width: 90rem; margin: 0 auto; }

      /* Sidebar */
      .sidebar {
        position: sticky; top: 3.5rem; width: 15rem; flex-shrink: 0;
        height: calc(100vh - 3.5rem); overflow-y: auto;
        border-right: 1px solid rgba(229,229,229,0.7); padding: 1.5rem 1rem;
      }
      .sidebar::-webkit-scrollbar { width: 4px; }
      .sidebar::-webkit-scrollbar-thumb { background: #d4d4d4; border-radius: 9999px; }
      .sidebar-group { margin-bottom: 0.5rem; }
      .sidebar-group-title {
        display: flex; align-items: center; justify-content: space-between;
        font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.05em; color: var(--color-muted);
        padding: 0.4rem 0.5rem; cursor: pointer; border-radius: 0.5rem;
        transition: color 0.15s;
      }
      .sidebar-group-title:hover { color: var(--color-fg); }
      .sidebar-toggle-icon { width: 14px; height: 14px; transition: transform 0.2s; }
      .sidebar-toggle-icon.collapsed { transform: rotate(-90deg); }
      .sidebar-items { display: flex; flex-direction: column; gap: 0.125rem; }
      .sidebar-items.hidden { display: none; }
      .sidebar-item {
        display: block; padding: 0.35rem 0.625rem; border-radius: 0.5rem;
        font-size: 0.875rem; color: var(--color-muted);
        transition: background 0.15s, color 0.15s;
      }
      .sidebar-item:hover { background: #f5f5f5; color: var(--color-fg); text-decoration: none; }
      .sidebar-item.active { background: var(--color-accent-light); color: var(--color-accent); font-weight: 500; }
      @media (max-width: 768px) { .sidebar { display: none; } }

      /* Content */
      .content { flex: 1; min-width: 0; padding: 2rem 2.5rem; max-width: 48rem; }
      .content h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.35rem; letter-spacing: -0.02em; }
      .content h2 { font-size: 1.5rem; font-weight: 600; margin-top: 2.5rem; margin-bottom: 0.75rem; scroll-margin-top: 4rem; }
      .content h3 { font-size: 1.2rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.5rem; scroll-margin-top: 4rem; }
      .content p { margin-bottom: 1rem; }
      .content ul, .content ol { margin: 1rem 0; padding-left: 1.5rem; }
      .content li { margin-bottom: 0.25rem; }
      .content strong { font-weight: 600; }

      .content pre {
        overflow-x: auto; border-radius: 0.75rem;
        border: 1px solid var(--color-border); background: var(--color-surface);
        padding: 1rem 1.25rem; margin: 1rem 0; font-size: 0.875rem; line-height: 1.6;
      }
      .content code { font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 0.875em; }
      .content :not(pre) > code {
        background: #f5f5f5; color: var(--color-accent);
        padding: 0.15rem 0.4rem; border-radius: 0.35rem; font-weight: 500;
      }

      .content table {
        width: 100%; font-size: 0.875rem; border-collapse: collapse;
        margin: 1rem 0; border-radius: 0.5rem; overflow: hidden; border: 1px solid var(--color-border);
      }
      .content th { background: var(--color-surface); font-weight: 600; text-align: left; padding: 0.6rem 1rem; border-bottom: 1px solid var(--color-border); }
      .content td { padding: 0.6rem 1rem; border-bottom: 1px solid #f5f5f5; }
      .content tr:last-child td { border-bottom: none; }

      .content blockquote {
        border-left: 4px solid #c4b5fd; background: rgba(245,243,255,0.5);
        padding: 0.5rem 1rem; margin: 1rem 0; border-radius: 0 0.5rem 0.5rem 0;
        color: var(--color-muted); font-style: italic;
      }
      .content hr { border: none; border-top: 1px solid var(--color-border); margin: 2rem 0; }
      .content img { max-width: 100%; border-radius: 0.5rem; }
      .content-description { font-size: 1.125rem; color: var(--color-muted); margin-bottom: 2rem; line-height: 1.6; }

      @media (max-width: 768px) { .content { padding: 1.5rem 1.25rem; } }

      /* ToC */
      .toc {
        position: sticky; top: 3.5rem; width: 14rem; flex-shrink: 0;
        height: calc(100vh - 3.5rem); overflow-y: auto;
        padding: 1.5rem 1rem 1.5rem 0; font-size: 0.825rem; display: none;
      }
      @media (min-width: 1280px) { .toc { display: block; } }
      .toc-title {
        font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.06em; color: var(--color-muted); margin-bottom: 0.75rem;
      }
      .toc-link {
        display: block; padding: 0.3rem 0; color: var(--color-muted);
        border-left: 2px solid transparent; padding-left: 0.75rem;
        transition: color 0.15s, border-color 0.15s; line-height: 1.4;
      }
      .toc-link:hover { color: var(--color-fg); text-decoration: none; }
      .toc-link.active { color: var(--color-accent); font-weight: 500; border-left-color: var(--color-accent); }
      .toc-link.level-3 { padding-left: 1.5rem; }
    </style>
  </head>
  <body>
    <!-- Navbar -->
    <header class="navbar">
      <div class="navbar-inner">
        <a href="/" class="navbar-logo">
          <span class="navbar-logo-icon">W</span> Wiki
        </a>
        <button class="hamburger" id="hamburger" aria-label="菜单">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/>
          </svg>
        </button>
        <nav class="navbar-links" id="navbar-links">
          <button class="navbar-link" id="search-btn" style="cursor:pointer;background:none;border:none;font-family:inherit;font-size:0.875rem">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:0.35rem"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            搜索
          </button>
          <a href="/docs/getting-started" class="navbar-link">文档</a>
          <a href="https://github.com" target="_blank" rel="noreferrer" class="navbar-link" style="padding:0.375rem" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <div class="docs-container">
      <!-- Sidebar (rendered from _meta.ts) -->
      <aside class="sidebar" id="sidebar">
        <nav>
          <div class="sidebar-group">
            <a href="/" class="sidebar-item" style="font-weight:600">← 首页</a>
          </div>
          <Fragment set:html={renderSidebar(sidebar)} />
        </nav>
      </aside>

      <!-- Content -->
      <main class="content" id="content">
        <h1>{title}</h1>
        {description && <p class="content-description">{description}</p>}
        <slot />
      </main>

      <!-- ToC -->
      <aside class="toc">
        <div class="toc-title">本页目录</div>
        <nav id="toc-nav">
          {headings.length > 0 && headings.map((h) => (
            <a
              href={`#${h.slug}`}
              class={`toc-link${h.depth === 3 ? ' level-3' : ''}`}
              data-heading={h.slug}
            >
              {h.text}
            </a>
          ))}
        </nav>
      </aside>
    </div>

    <!-- Search dialog -->
    <div id="search-overlay" style="display:none;position:fixed;inset:0;z-index:100;background:rgba(0,0,0,0.3);backdrop-filter:blur(4px)"></div>
    <div id="search-dialog" style="display:none;position:fixed;top:20%;left:50%;transform:translateX(-50%);z-index:101;width:90%;max-width:560px;background:#fff;border-radius:0.85rem;box-shadow:0 20px 60px rgba(0,0,0,0.15);overflow:hidden">
      <div style="display:flex;align-items:center;padding:0.75rem 1rem;border-bottom:1px solid #e5e5e5">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#737373" stroke-width="2" style="flex-shrink:0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input id="search-input" type="text" placeholder="搜索文档..." style="flex:1;border:none;outline:none;font-size:1rem;padding:0.25rem 0.75rem;font-family:inherit" />
        <button id="search-close" style="background:none;border:none;cursor:pointer;padding:0.25rem;color:#737373;font-size:1.25rem;line-height:1">&times;</button>
      </div>
      <div id="search-results" style="max-height:400px;overflow-y:auto;font-size:0.875rem"></div>
      <div id="search-empty" style="display:none;padding:2rem;text-align:center;color:#737373">未找到结果</div>
    </div>

    <Fragment set:html="<script src='/_pagefind/pagefind.js'></script>" />

    <script>
      // ── Active sidebar & navbar ──
      const path = location.pathname.replace(/\/$/, '').replace('/index.html', '') || '/';
      document.querySelectorAll('.sidebar-item').forEach(el => {
        const href = el.getAttribute('href');
        if (href && (path === href || path === href + '/' || path.startsWith(href + '/'))) {
          el.classList.add('active');
        }
      });
      document.querySelectorAll('.navbar-link').forEach(el => {
        const href = el.getAttribute('href');
        if (href && path.startsWith(href)) el.classList.add('active');
      });

      // ── Mobile hamburger ──
      document.getElementById('hamburger')?.addEventListener('click', () => {
        document.getElementById('navbar-links')?.classList.toggle('open');
      });

      // ── Collapsible sidebar groups ──
      document.querySelectorAll('.sidebar-group-title').forEach(title => {
        title.addEventListener('click', () => {
          const groupId = title.dataset.group;
          const items = document.getElementById('group-' + groupId);
          const icon = title.querySelector('.sidebar-toggle-icon');
          items?.classList.toggle('hidden');
          icon?.classList.toggle('collapsed');
        });
      });

      // ── ToC scroll spy ──
      (function() {
        const tocLinks = Array.from(document.querySelectorAll('.toc-link'));
        if (tocLinks.length === 0) return;
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              tocLinks.forEach(t => t.classList.remove('active'));
              const active = tocLinks.find(t => t.dataset.heading === entry.target.id);
              active?.classList.add('active');
            }
          });
        }, { rootMargin: '-80px 0px -75% 0px' });
        tocLinks.forEach(t => {
          const el = document.getElementById(t.dataset.heading || '');
          if (el) observer.observe(el);
        });
      })();

      // ── Search ──
      const searchOverlay = document.getElementById('search-overlay');
      const searchDialog = document.getElementById('search-dialog');
      const searchInput = document.getElementById('search-input');
      const searchResults = document.getElementById('search-results');
      const searchEmpty = document.getElementById('search-empty');

      function openSearch() {
        searchOverlay.style.display = 'block';
        searchDialog.style.display = 'block';
        searchInput.focus();
        document.body.style.overflow = 'hidden';
      }

      function closeSearch() {
        searchOverlay.style.display = 'none';
        searchDialog.style.display = 'none';
        searchInput.value = '';
        searchResults.innerHTML = '';
        searchEmpty.style.display = 'none';
        document.body.style.overflow = '';
      }

      document.getElementById('search-btn').addEventListener('click', openSearch);
      document.getElementById('search-close').addEventListener('click', closeSearch);
      searchOverlay.addEventListener('click', closeSearch);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
          e.preventDefault();
          openSearch();
        }
        if (e.key === 'Escape') closeSearch();
      });

      let pagefindInstance = null;

      searchInput.addEventListener('input', async function() {
        const query = this.value.trim();
        if (!query) {
          searchResults.innerHTML = '';
          searchEmpty.style.display = 'none';
          return;
        }
        try {
          if (!pagefindInstance && typeof Pagefind !== 'undefined') {
            pagefindInstance = Pagefind;
          }
          if (!pagefindInstance) {
            searchResults.innerHTML = '<div style="padding:2rem;text-align:center;color:#737373">搜索组件加载中...</div>';
            return;
          }
          const search = await pagefindInstance.search(query);
          if (!search || !search.results || search.results.length === 0) {
            searchResults.innerHTML = '';
            searchEmpty.style.display = 'block';
            return;
          }
          searchEmpty.style.display = 'none';
          const results = await Promise.all(search.results.slice(0, 10).map(r => r.data()));
          searchResults.innerHTML = results.map(r => `
            <a href="${(r.url||'').replace(/\.html$/, '').replace(/\/index$/, '')}" style="display:block;padding:0.75rem 1rem;border-bottom:1px solid #f0f0f0;color:inherit;text-decoration:none;transition:background 0.1s"
               onmouseover="this.style.background='#f5f5f5'" onmouseout="this.style.background=''">
              <div style="font-weight:600;margin-bottom:0.15rem">${r.meta.title}</div>
              <div style="font-size:0.825rem;color:#737373">${r.excerpt || ''}</div>
            </a>
          `).join('');
        } catch(e) {
          console.warn('Search error:', e);
        }
      });
    </script>
  </body>
</html>
