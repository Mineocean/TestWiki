---
export interface Props {
  title: string
  description?: string
}

const { title, description } = Astro.props
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Markdown Wiki</title>
    {description && <meta name="description" content={description} />}

    <!-- Inter font -->
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <style is:global>
      :root {
        --color-bg: #fff;
        --color-fg: #171717;
        --color-muted: #737373;
        --color-border: #e5e5e5;
        --color-accent: #7c3aed;
        --color-accent-light: #f5f3ff;
        --color-surface: #fafafa;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { scroll-behavior: smooth; }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--color-bg);
        color: var(--color-fg);
        line-height: 1.7;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }

      a { color: var(--color-accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* ── Navbar ── */
      .navbar {
        position: sticky; top: 0; z-index: 50;
        border-bottom: 1px solid rgba(229,229,229,0.7);
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        height: 3.5rem;
      }
      .navbar-inner {
        display: flex; align-items: center; justify-content: space-between;
        max-width: 90rem; margin: 0 auto; height: 100%;
        padding: 0 1.25rem;
      }
      .navbar-logo {
        display: flex; align-items: center; gap: 0.5rem;
        font-weight: 700; font-size: 1rem; color: var(--color-fg); text-decoration: none;
      }
      .navbar-logo-icon {
        display: flex; align-items: center; justify-content: center;
        width: 1.75rem; height: 1.75rem;
        border-radius: 0.5rem; background: var(--color-accent);
        color: #fff; font-size: 0.75rem; font-weight: 700;
      }

      .navbar-links { display: flex; align-items: center; gap: 0.25rem; }
      .navbar-link, .navbar-github {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 0.375rem 0.75rem; border-radius: 0.5rem;
        font-size: 0.875rem; color: var(--color-muted);
        transition: background 0.15s, color 0.15s;
      }
      .navbar-link:hover, .navbar-github:hover {
        background: #f5f5f5; color: var(--color-fg); text-decoration: none;
      }
      .navbar-link.active { background: var(--color-accent-light); color: var(--color-accent); }
      .navbar-github { padding: 0.375rem; }

      .hamburger {
        display: none; background: none; border: none; cursor: pointer;
        padding: 0.375rem; border-radius: 0.5rem; color: var(--color-muted);
      }
      .hamburger:hover { background: #f5f5f5; color: var(--color-fg); }
      @media (max-width: 768px) {
        .hamburger { display: flex; }
        .navbar-links { display: none; }
        .navbar-links.open {
          display: flex; flex-direction: column; position: absolute;
          top: 3.5rem; left: 0; right: 0;
          background: #fff; border-bottom: 1px solid var(--color-border);
          padding: 0.5rem 1rem; gap: 0;
        }
        .navbar-links.open .navbar-link { width: 100%; padding: 0.5rem 0.75rem; }
      }

      /* ── Layout ── */
      .docs-container {
        display: flex; max-width: 90rem; margin: 0 auto;
      }

      /* ── Sidebar ── */
      .sidebar {
        position: sticky; top: 3.5rem;
        width: 15rem; flex-shrink: 0;
        height: calc(100vh - 3.5rem);
        overflow-y: auto;
        border-right: 1px solid rgba(229,229,229,0.7);
        padding: 1.5rem 1rem;
      }
      .sidebar::-webkit-scrollbar { width: 4px; }
      .sidebar::-webkit-scrollbar-thumb { background: #d4d4d4; border-radius: 9999px; }

      .sidebar-group { margin-bottom: 1.25rem; }
      .sidebar-group-title {
        display: flex; align-items: center; justify-content: space-between;
        font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.05em; color: var(--color-muted);
        padding: 0.25rem 0.5rem; margin-bottom: 0.125rem;
        cursor: pointer; border-radius: 0.5rem;
        transition: color 0.15s;
      }
      .sidebar-group-title:hover { color: var(--color-fg); }

      .sidebar-toggle-icon {
        width: 14px; height: 14px; transition: transform 0.2s;
      }
      .sidebar-toggle-icon.collapsed { transform: rotate(-90deg); }

      .sidebar-items {
        display: flex; flex-direction: column; gap: 0.125rem;
        overflow: hidden; transition: max-height 0.25s ease;
      }
      .sidebar-items.hidden { max-height: 0 !important; }

      .sidebar-item {
        display: block; padding: 0.35rem 0.625rem; border-radius: 0.5rem;
        font-size: 0.875rem; color: var(--color-muted);
        transition: background 0.15s, color 0.15s;
      }
      .sidebar-item:hover { background: #f5f5f5; color: var(--color-fg); text-decoration: none; }
      .sidebar-item.active { background: var(--color-accent-light); color: var(--color-accent); font-weight: 500; }

      @media (max-width: 768px) {
        .sidebar { display: none; }
      }

      /* ── Content ── */
      .content {
        flex: 1; min-width: 0;
        padding: 2rem 2.5rem; max-width: 48rem;
      }
      .content h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.35rem; letter-spacing: -0.02em; }
      .content h2 {
        font-size: 1.5rem; font-weight: 600;
        margin-top: 2.5rem; margin-bottom: 0.75rem;
        scroll-margin-top: 4rem; letter-spacing: -0.01em;
      }
      .content h3 {
        font-size: 1.2rem; font-weight: 600;
        margin-top: 2rem; margin-bottom: 0.5rem;
        scroll-margin-top: 4rem;
      }
      .content p { margin-bottom: 1rem; }
      .content ul, .content ol { margin: 1rem 0; padding-left: 1.5rem; }
      .content li { margin-bottom: 0.25rem; }
      .content strong { font-weight: 600; }

      .content pre {
        overflow-x: auto; border-radius: 0.75rem;
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        padding: 1rem 1.25rem; margin: 1rem 0;
        font-size: 0.875rem; line-height: 1.6;
      }
      .content code {
        font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
        font-size: 0.875em;
      }
      .content :not(pre) > code {
        background: #f5f5f5; color: var(--color-accent);
        padding: 0.15rem 0.4rem; border-radius: 0.35rem;
        font-weight: 500; font-size: 0.875em;
      }

      .content table {
        width: 100%; font-size: 0.875rem; border-collapse: collapse;
        margin: 1rem 0; border-radius: 0.5rem; overflow: hidden;
        border: 1px solid var(--color-border);
      }
      .content th {
        background: var(--color-surface); font-weight: 600;
        text-align: left; padding: 0.6rem 1rem;
        border-bottom: 1px solid var(--color-border);
      }
      .content td {
        padding: 0.6rem 1rem;
        border-bottom: 1px solid #f5f5f5;
      }
      .content tr:last-child td { border-bottom: none; }

      .content blockquote {
        border-left: 4px solid #c4b5fd;
        background: rgba(245,243,255,0.5);
        padding: 0.5rem 1rem; margin: 1rem 0; border-radius: 0 0.5rem 0.5rem 0;
        color: var(--color-muted);
        font-style: italic;
      }

      .content hr { border: none; border-top: 1px solid var(--color-border); margin: 2rem 0; }

      .content img { max-width: 100%; border-radius: 0.5rem; }

      .content-description {
        font-size: 1.125rem; color: var(--color-muted);
        margin-bottom: 2rem; line-height: 1.6;
      }

      .content > *:first-child { margin-top: 0; }

      @media (max-width: 768px) {
        .content { padding: 1.5rem 1.25rem; }
      }

      /* ── ToC ── */
      .toc {
        position: sticky; top: 3.5rem;
        width: 14rem; flex-shrink: 0;
        height: calc(100vh - 3.5rem);
        overflow-y: auto;
        padding: 1.5rem 1rem 1.5rem 0;
        font-size: 0.825rem;
        display: none;
      }
      @media (min-width: 1280px) {
        .toc { display: block; }
      }

      .toc-title {
        font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.06em; color: var(--color-muted);
        margin-bottom: 0.75rem;
      }
      .toc-link {
        display: block; padding: 0.3rem 0;
        color: var(--color-muted); text-decoration: none;
        border-left: 2px solid transparent; padding-left: 0.75rem;
        transition: color 0.15s, border-color 0.15s;
        line-height: 1.4;
      }
      .toc-link:hover { color: var(--color-fg); text-decoration: none; }
      .toc-link.active {
        color: var(--color-accent); font-weight: 500;
        border-left-color: var(--color-accent);
      }
      .toc-link.level-3 { padding-left: 1.5rem; }

      /* ── Footer ── */
      .content-footer {
        margin-top: 3rem; padding-top: 1.5rem;
        border-top: 1px solid var(--color-border);
        display: flex; justify-content: space-between;
        font-size: 0.875rem;
      }
      .content-footer a { color: var(--color-muted); }
      .content-footer a:hover { color: var(--color-fg); }
    </style>
  </head>
  <body>
    <!-- ═══════ Navbar ═══════ -->
    <header class="navbar">
      <div class="navbar-inner">
        <a href="/" class="navbar-logo">
          <span class="navbar-logo-icon">W</span>
          Wiki
        </a>
        <button class="hamburger" id="hamburger" aria-label="菜单">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4" x2="20" y1="6" y2="6"/>
            <line x1="4" x2="20" y1="12" y2="12"/>
            <line x1="4" x2="20" y1="18" y2="18"/>
          </svg>
        </button>
        <nav class="navbar-links" id="navbar-links">
          <a href="/getting-started" class="navbar-link">文档</a>
          <a href="https://github.com" target="_blank" rel="noreferrer" class="navbar-github" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <div class="docs-container">
      <!-- ═══════ Sidebar ═══════ -->
      <aside class="sidebar" id="sidebar">
        <nav>
          <div class="sidebar-group">
            <div class="sidebar-group-title" data-group="start">
              起步
              <svg class="sidebar-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
            <div class="sidebar-items" id="group-start">
              <a href="/getting-started" class="sidebar-item">快速开始</a>
            </div>
          </div>
          <div class="sidebar-group">
            <div class="sidebar-group-title" data-group="dev">
              开发指南
              <svg class="sidebar-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
            <div class="sidebar-items" id="group-dev">
              <a href="/dev/architecture" class="sidebar-item">架构设计</a>
              <a href="/dev/api-reference" class="sidebar-item">接口说明</a>
            </div>
          </div>
        </nav>
      </aside>

      <!-- ═══════ Content ═══════ -->
      <main class="content" id="content">
        <h1>{title}</h1>
        {description && <p class="content-description">{description}</p>}
        <slot />
      </main>

      <!-- ═══════ ToC ═══════ -->
      <aside class="toc">
        <div class="toc-title">本页目录</div>
        <nav id="toc-nav"></nav>
      </aside>
    </div>

    <!-- ═══════ Scripts ═══════ -->
    <script>
      // ── Active sidebar item ──
      const path = location.pathname.replace(/\/$/, '').replace('/index.html', '') || '/';
      document.querySelectorAll('.sidebar-item').forEach(el => {
        const href = el.getAttribute('href');
        if (href === path || href === path + '/' || path.endsWith(href?.replace(/\/$/, '') || '')) {
          el.classList.add('active');
        }
      });
      // Active navbar
      document.querySelectorAll('.navbar-link').forEach(el => {
        const href = el.getAttribute('href');
        if (href && (path.startsWith(href) || path === href)) {
          el.classList.add('active');
        }
      });

      // ── Mobile hamburger ──
      const hamburger = document.getElementById('hamburger');
      const navbarLinks = document.getElementById('navbar-links');
      hamburger?.addEventListener('click', () => {
        navbarLinks?.classList.toggle('open');
      });

      // ── Collapsible sidebar groups ──
      document.querySelectorAll('.sidebar-group-title').forEach(title => {
        title.addEventListener('click', () => {
          const groupId = title.dataset.group;
          const items = document.getElementById('group-' + groupId);
          const icon = title.querySelector('.sidebar-toggle-icon');
          items?.classList.toggle('hidden');
          icon?.classList.toggle('collapsed');
        });
      });

      // ── ToC generation + scroll spy ──
      (function() {
        const headings = Array.from(document.querySelectorAll('.content h2, .content h3'));
        if (headings.length === 0) return;

        const tocNav = document.getElementById('toc-nav');
        const tocLinks = [];

        headings.forEach((h, i) => {
          if (!h.id) h.id = 'heading-' + i;
          const link = document.createElement('a');
          link.href = '#' + h.id;
          link.className = 'toc-link' + (h.tagName === 'H3' ? ' level-3' : '');
          link.textContent = h.textContent;
          link.addEventListener('click', (e) => {
            e.preventDefault();
            document.getElementById(h.id)?.scrollIntoView({ behavior: 'smooth' });
          });
          tocNav?.appendChild(link);
          tocLinks.push({ link, id: h.id });
        });

        if (tocLinks.length > 0) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                tocLinks.forEach(t => t.link.classList.remove('active'));
                const active = tocLinks.find(t => t.id === entry.target.id);
                active?.link.classList.add('active');
              }
            });
          }, { rootMargin: '-80px 0px -75% 0px' });

          tocLinks.forEach(t => {
            const el = document.getElementById(t.id);
            if (el) observer.observe(el);
          });
        }
      })();
    </script>
  </body>
</html>
