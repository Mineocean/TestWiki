---
import type { MetaEntry } from '../lib/sidebar'
import { renderSidebar } from '../lib/sidebar'
import '../styles/tokens.css'
import SearchDialog from '../components/SearchDialog.astro'

export interface Props {
  title: string
  description?: string
  sidebar: MetaEntry[]
  headings?: { depth: number; slug: string; text: string }[]
}

const { title, description, sidebar, headings = [] } = Astro.props
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (function(){var t=localStorage.getItem('theme');if(!t)t=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';document.documentElement.setAttribute('data-theme',t)})();
    </script>
    <title>{title} | Sage</title>
    {description && <meta name="description" content={description} />}

    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <style is:global>
      /* ═══════════════════════════════════════════════════
         Layout Styles (tokens → tokens.css)
         ═══════════════════════════════════════════════════ */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
        overflow-x: hidden;
        color-scheme: light dark;
      }
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--color-bg);
        color: var(--color-fg);
        line-height: 1.7;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
        transition: background 0.3s ease, color 0.3s ease;
      }
      a {
        color: var(--color-accent);
        text-decoration: none;
        transition: color 0.15s;
      }
      a:hover {
        text-decoration: underline;
      }
      ::selection {
        background: var(--color-accent);
        color: #fff;
      }

      /* ═══════════════════════════════════════════════════
         Navbar
         ═══════════════════════════════════════════════════ */
      .navbar {
        position: sticky;
        top: 0;
        z-index: 50;
        border-bottom: 1px solid var(--color-border);
        background: var(--color-nav-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        height: 3.5rem;
        transition: background 0.3s ease, border-color 0.3s ease;
      }
      .navbar-inner {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        max-width: 90rem;
        margin: 0 auto;
        height: 100%;
        padding: 0 1.25rem;
      }
      .navbar-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 700;
        font-size: 1rem;
        color: var(--color-fg);
        text-decoration: none;
        flex-shrink: 0;
        margin-right: auto;
        transition: color 0.3s ease;
      }
      .navbar-logo-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.75rem;
        height: 1.75rem;
        border-radius: 0.5rem;
        background: var(--color-accent);
        color: #fff;
        font-size: 0.75rem;
        font-weight: 700;
      }
      .navbar-links {
        display: flex;
        align-items: center;
        gap: 0.125rem;
        flex-shrink: 0;
      }
      .navbar-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.4rem 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        color: var(--color-muted);
        transition: background 0.15s, color 0.15s;
        background: none;
        border: none;
        cursor: pointer;
        font-family: inherit;
        white-space: nowrap;
      }
      .navbar-link:hover {
        background: var(--color-code-bg);
        color: var(--color-fg);
        text-decoration: none;
      }
      .navbar-link.active {
        background: var(--color-accent-soft);
        color: var(--color-accent);
      }
      .navbar-link.nav-icon-btn {
        padding: 0.375rem;
      }
      .sidebar-home-link {
        font-weight: 600;
      }
      .nav-spacer {
        flex: 1;
      }
      .hamburger {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.4rem;
        border-radius: 0.5rem;
        color: var(--color-muted);
        flex-shrink: 0;
        transition: background 0.15s, color 0.15s;
      }
      .hamburger:hover {
        background: var(--color-code-bg);
        color: var(--color-fg);
      }

      /* ═══════════════════════════════════════════════════
         Sidebar Overlay (mobile)
         ═══════════════════════════════════════════════════ */
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 45;
        background: var(--color-overlay);
      }

      @media (max-width: 768px) {
        .hamburger {
          display: flex;
        }
        .sidebar {
          position: fixed !important;
          top: 3.5rem !important;
          left: 0;
          bottom: 0;
          z-index: 46;
          background: var(--color-bg);
          transform: translateX(-100%);
          transition: transform 0.25s ease, background 0.3s ease;
          width: 17rem !important;
          height: auto !important;
          box-shadow: var(--shadow-sidebar);
        }
        .sidebar.open {
          transform: translateX(0);
        }
        .sidebar-overlay.open {
          display: block;
        }
        .content {
          padding: 1.5rem 1rem !important;
        }
        .content h1 {
          font-size: 1.6rem !important;
        }
        .content h2 {
          font-size: 1.25rem !important;
        }
        .content h3 {
          font-size: 1.05rem !important;
        }
      }
      @media (min-width: 769px) {
        .sidebar-overlay {
          display: none !important;
        }
      }

      /* ═══════════════════════════════════════════════════
         Layout
         ═══════════════════════════════════════════════════ */
      .docs-container {
        display: flex;
        max-width: 90rem;
        margin: 0 auto;
      }

      /* ── Sidebar ── */
      .sidebar {
        position: sticky;
        top: 3.5rem;
        width: 15rem;
        flex-shrink: 0;
        height: calc(100vh - 3.5rem);
        overflow-y: auto;
        border-right: 1px solid var(--color-border);
        padding: 1.5rem 1rem;
        transition: border-color 0.3s ease;
      }
      .sidebar::-webkit-scrollbar {
        width: 4px;
      }
      .sidebar::-webkit-scrollbar-thumb {
        background: var(--color-scrollbar-thumb);
        border-radius: 9999px;
      }
      .sidebar-group {
        margin-bottom: 1rem;
      }
      .sidebar-group-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--color-muted);
        padding: 0.4rem 0.5rem;
        cursor: pointer;
        border-radius: 0.5rem;
        transition: color 0.15s;
        width: 100%;
        background: none;
        border: none;
        font-family: inherit;
      }
      .sidebar-group-title:hover {
        color: var(--color-fg);
      }
      .sidebar-toggle-icon {
        width: 13px;
        height: 13px;
        transition: transform 0.2s;
        flex-shrink: 0;
      }
      .sidebar-toggle-icon.collapsed {
        transform: rotate(-90deg);
      }
      .sidebar-items {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
      }
      .sidebar-items.hidden {
        display: none;
      }
      .sidebar-item {
        display: block;
        padding: 0.4rem 0.625rem;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        color: var(--color-muted);
        transition: background 0.15s, color 0.15s;
        line-height: 1.5;
        text-decoration: none;
      }
      .sidebar-item:hover {
        background: var(--color-code-bg);
        color: var(--color-fg);
        text-decoration: none;
      }
      .sidebar-item.active {
        background: var(--color-accent-soft);
        color: var(--color-accent);
        font-weight: 500;
      }

      /* ═══════════════════════════════════════════════════
         Content
         ═══════════════════════════════════════════════════ */
      .content {
        flex: 1;
        min-width: 0;
        padding: 2.5rem 3rem;
        max-width: 50rem;
      }
      .content h1 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 0.35rem;
        letter-spacing: -0.02em;
        line-height: 1.3;
        color: var(--color-fg);
      }
      .content h2 {
        font-size: 1.5rem;
        font-weight: 600;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        scroll-margin-top: 4rem;
        letter-spacing: -0.01em;
        color: var(--color-fg);
      }
      .content h3 {
        font-size: 1.2rem;
        font-weight: 600;
        margin-top: 2rem;
        margin-bottom: 0.5rem;
        scroll-margin-top: 4rem;
        color: var(--color-fg-secondary);
      }
      .content p {
        margin-bottom: 1rem;
        word-break: break-word;
      }
      .content ul,
      .content ol {
        margin: 1rem 0;
        padding-left: 1.5rem;
      }
      .content li {
        margin-bottom: 0.35rem;
      }
      .content li::marker {
        color: var(--color-muted);
      }
      .content strong {
        font-weight: 600;
      }
      .content pre {
        overflow-x: auto;
        border-radius: 0.75rem;
        border: 1px solid var(--color-border);
        background: var(--color-code-bg);
        padding: 1rem 1.25rem;
        margin: 1rem 0;
        font-size: 0.85rem;
        line-height: 1.65;
        -webkit-overflow-scrolling: touch;
        transition: background 0.3s ease, border-color 0.3s ease;
      }
      .content pre::-webkit-scrollbar {
        height: 6px;
      }
      .content pre::-webkit-scrollbar-thumb {
        background: var(--color-scrollbar-thumb);
        border-radius: 9999px;
      }
      .content code {
        font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
        font-size: 0.875em;
      }
      .content :not(pre) > code {
        background: var(--color-code-bg);
        color: var(--color-accent);
        padding: 0.15rem 0.4rem;
        border-radius: 0.35rem;
        font-weight: 500;
        word-break: break-all;
        transition: background 0.3s ease;
      }
      .content table {
        width: 100%;
        font-size: 0.875rem;
        border-collapse: collapse;
        margin: 1rem 0;
        border-radius: 0.5rem;
        overflow: hidden;
        border: 1px solid var(--color-border);
        display: block;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        transition: border-color 0.3s ease;
      }
      .content th {
        background: var(--color-table-header-bg);
        font-weight: 600;
        text-align: left;
        padding: 0.6rem 1rem;
        border-bottom: 1px solid var(--color-border);
        white-space: nowrap;
        transition: background 0.3s ease, border-color 0.3s ease;
      }
      .content td {
        padding: 0.6rem 1rem;
        border-bottom: 1px solid var(--color-table-cell-border);
        transition: border-color 0.3s ease;
      }
      .content tr:last-child td {
        border-bottom: none;
      }
      .content blockquote {
        border-left: 4px solid var(--color-blockquote-border);
        background: var(--color-blockquote-bg);
        padding: 0.5rem 1rem;
        margin: 1rem 0;
        border-radius: 0 0.5rem 0.5rem 0;
        color: var(--color-muted);
        transition: background 0.3s ease, border-color 0.3s ease;
      }
      .content hr {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 2.5rem 0;
        transition: border-color 0.3s ease;
      }
      .content img {
        max-width: 100%;
        border-radius: 0.5rem;
        height: auto;
      }
      .content-description {
        font-size: 1.1rem;
        color: var(--color-muted);
        margin-bottom: 2rem;
        line-height: 1.6;
      }

      @media (max-width: 1024px) {
        .content {
          padding: 2rem 1.5rem;
        }
      }

      /* ═══════════════════════════════════════════════════
         Table of Contents
         ═══════════════════════════════════════════════════ */
      .toc {
        position: sticky;
        top: 3.5rem;
        width: 13rem;
        flex-shrink: 0;
        height: calc(100vh - 3.5rem);
        overflow-y: auto;
        padding: 1.5rem 0.75rem 1.5rem 0;
        font-size: 0.8rem;
        display: none;
      }
      @media (min-width: 1280px) {
        .toc {
          display: block;
        }
      }
      .toc::-webkit-scrollbar {
        width: 4px;
      }
      .toc::-webkit-scrollbar-thumb {
        background: var(--color-scrollbar-thumb);
        border-radius: 9999px;
      }
      .toc-title {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--color-muted);
        margin-bottom: 0.75rem;
        padding-left: 0.75rem;
      }
      .toc-link {
        display: block;
        padding: 0.35rem 0;
        color: var(--color-muted);
        border-left: 2px solid transparent;
        padding-left: 0.75rem;
        transition: color 0.15s, border-color 0.15s;
        line-height: 1.4;
        text-decoration: none;
        font-size: 0.8rem;
      }
      .toc-link:hover {
        color: var(--color-fg);
        text-decoration: none;
      }
      .toc-link.active {
        color: var(--color-accent);
        font-weight: 500;
        border-left-color: var(--color-accent);
      }
      .toc-link.level-3 {
        padding-left: 1.5rem;
      }

      /* ═══════════════════════════════════════════════════
         Search Dialog
         ═══════════════════════════════════════════════════ */
      #search-overlay {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 100;
        background: var(--color-overlay);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
      }
      #search-dialog {
        display: none;
        position: fixed;
        top: 15%;
        left: 50%;
        transform: translateX(-50%);
        z-index: 101;
        width: calc(100vw - 2rem);
        max-width: 520px;
        background: var(--color-search-bg);
        border: 1px solid var(--color-border);
        border-radius: 0.85rem;
        box-shadow: var(--shadow-md);
        overflow: hidden;
        transition: background 0.3s ease, border-color 0.3s ease;
      }
      #search-dialog.open-dialog {
        display: block;
      }
      .search-results {
        max-height: 400px;
        overflow-y: auto;
      }
      @media (max-width: 640px) {
        #search-dialog {
          top: 5%;
          max-height: 80vh;
          display: none;
        }
        #search-dialog.open-dialog {
          display: flex;
          flex-direction: column;
        }
        .search-results {
          flex: 1;
          overflow-y: auto;
        }
      }
      .search-header {
        display: flex;
        align-items: center;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--color-border);
        gap: 0.5rem;
        transition: border-color 0.3s ease;
      }
      .search-header svg {
        flex-shrink: 0;
        color: var(--color-muted);
      }
      .search-header input {
        flex: 1;
        border: none;
        outline: none;
        font-size: 1rem;
        padding: 0.25rem 0.5rem;
        font-family: inherit;
        background: transparent;
        color: var(--color-fg);
        transition: color 0.3s ease;
      }
      .search-header input::placeholder {
        color: var(--color-muted);
      }
      .search-close-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.25rem 0.5rem;
        color: var(--color-muted);
        font-size: 1.25rem;
        line-height: 1;
        border-radius: 0.35rem;
        transition: background 0.15s, color 0.15s;
      }
      .search-close-btn:hover {
        background: var(--color-code-bg);
      }
      .search-result-item {
        display: block;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--color-border-light);
        color: inherit;
        text-decoration: none;
        transition: background 0.1s, border-color 0.3s ease;
      }
      .search-result-item:hover,
      .search-result-item:focus {
        background: var(--color-search-hover);
        text-decoration: none;
      }
      .search-result-title {
        font-weight: 600;
        margin-bottom: 0.15rem;
        font-size: 0.875rem;
        color: var(--color-fg);
      }
      .search-result-excerpt {
        font-size: 0.8rem;
        color: var(--color-muted);
        line-height: 1.5;
      }
      .search-empty-state {
        display: none;
        padding: 2.5rem 1rem;
        text-align: center;
        color: var(--color-muted);
        font-size: 0.875rem;
      }

      /* ═══════════════════════════════════════════════════
         Theme Toggle
         ═══════════════════════════════════════════════════ */
      #theme-toggle {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 0.85rem;
        border: 1px solid var(--color-border);
        background: var(--color-surface-raised);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-muted);
        z-index: 10;
        box-shadow: var(--shadow-toggle);
        transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease,
          box-shadow 0.3s ease, transform 0.15s;
      }
      #theme-toggle:hover {
        color: var(--color-fg);
        border-color: var(--color-accent);
      }
      #theme-toggle:active {
        transform: scale(0.92);
      }
      #theme-toggle svg {
        transition: transform 0.3s ease, opacity 0.2s ease;
      }
    </style>
  </head>
  <body>
    <!-- Navbar -->
    <header class="navbar">
      <div class="navbar-inner">
        <a href="/" class="navbar-logo">
          <span class="navbar-logo-icon">S</span> Sage
        </a>
        <button class="hamburger" id="hamburger" aria-label="菜单">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/>
          </svg>
        </button>
        <nav class="navbar-links" id="navbar-links">
          <button class="navbar-link" id="search-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:0.35rem"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            搜索
          </button>
          <a href="https://github.com/Mineocean/TestWiki" target="_blank" rel="noreferrer" class="navbar-link nav-icon-btn" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
          </a>
          <button class="navbar-link nav-icon-btn" id="theme-toggle-nav" aria-label="切换主题">
            <svg id="ts-nav-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            <svg id="ts-nav-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </nav>
      </div>
    </header>

    <!-- Sidebar overlay for mobile -->
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <div class="docs-container">
      <!-- Sidebar -->
      <aside class="sidebar" id="sidebar">
        <nav>
          <div class="sidebar-group">
            <a href="/" class="sidebar-item sidebar-home-link">← 首页</a>
          </div>
          <Fragment set:html={renderSidebar(sidebar)} />
        </nav>
      </aside>

      <!-- Content -->
      <main class="content" id="content">
        <h1>{title}</h1>
        {description && <p class="content-description">{description}</p>}
        <slot />
      </main>

      <!-- ToC -->
      <aside class="toc">
        <div class="toc-title">本页目录</div>
        <nav id="toc-nav">
          {headings.length > 0 && headings.map((h) => (
            <a
              href={`#${h.slug}`}
              class={`toc-link${h.depth === 3 ? ' level-3' : ''}`}
              data-heading={h.slug}
            >
              {h.text}
            </a>
          ))}
        </nav>
      </aside>
    </div>

    <!-- Floating theme toggle -->
    <button id="theme-toggle" aria-label="切换主题">
      <svg id="theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
      <svg id="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>

    <!-- Search dialog (component) -->
    <SearchDialog />

    <script>
      // ═══════════════════════════════════════════════════
      // Theme (shared between floating toggle + navbar toggle)
      // ═══════════════════════════════════════════════════
      const FLOATING = {
        sun: document.getElementById('theme-icon-sun'),
        moon: document.getElementById('theme-icon-moon'),
      }
      const NAV = {
        sun: document.getElementById('ts-nav-sun'),
        moon: document.getElementById('ts-nav-moon'),
      }

      function applyTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme)
        const isDark = theme === 'dark'
        for (const pair of [FLOATING, NAV]) {
          if (pair.sun) pair.sun.style.display = isDark ? 'none' : 'block'
          if (pair.moon) pair.moon.style.display = isDark ? 'block' : 'none'
        }
      }

      // Sync icons (theme already set in <head>)
      const _t = document.documentElement.getAttribute('data-theme')
      if (_t) applyTheme(_t)

      function toggleTheme() {
        const current = document.documentElement.getAttribute('data-theme')
        const next = current === 'dark' ? 'light' : 'dark'
        applyTheme(next)
        localStorage.setItem('theme', next)
      }

      document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme)
      document.getElementById('theme-toggle-nav')?.addEventListener('click', toggleTheme)

      // ═══════════════════════════════════════════════════
      // Active sidebar & navbar
      // ═══════════════════════════════════════════════════
      const path = location.pathname.replace(/\/$/, '').replace('/index.html', '') || '/'
      document.querySelectorAll('.sidebar-item').forEach((el) => {
        const href = el.getAttribute('href')
        if (href && (path === href || path === href + '/' || path.startsWith(href + '/'))) {
          el.classList.add('active')
        }
      })
      document.querySelectorAll('.navbar-link').forEach((el) => {
        const href = el.getAttribute('href')
        if (href && path.startsWith(href)) el.classList.add('active')
      })

      // ═══════════════════════════════════════════════════
      // Mobile sidebar toggle
      // ═══════════════════════════════════════════════════
      const sidebar = document.getElementById('sidebar')
      const sidebarOverlay = document.getElementById('sidebar-overlay')

      function openSidebar() {
        sidebar?.classList.add('open')
        sidebarOverlay?.classList.add('open')
        document.body.style.overflow = 'hidden'
      }
      function closeSidebar() {
        sidebar?.classList.remove('open')
        sidebarOverlay?.classList.remove('open')
        document.body.style.overflow = ''
      }

      document.getElementById('hamburger')?.addEventListener('click', () => {
        sidebar?.classList.contains('open') ? closeSidebar() : openSidebar()
      })
      sidebarOverlay?.addEventListener('click', closeSidebar)

      // ═══════════════════════════════════════════════════
      // Collapsible sidebar groups
      // ═══════════════════════════════════════════════════
      document.querySelectorAll('.sidebar-group-title').forEach((title) => {
        title.addEventListener('click', () => {
          const groupId = title.dataset.group
          const items = document.getElementById('group-' + groupId)
          const icon = title.querySelector('.sidebar-toggle-icon')
          items?.classList.toggle('hidden')
          icon?.classList.toggle('collapsed')
        })
      })

      // ═══════════════════════════════════════════════════
      // ToC scroll spy
      // ═══════════════════════════════════════════════════
      ;(function () {
        const tocLinks = Array.from(document.querySelectorAll('.toc-link'))
        if (tocLinks.length === 0) return
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                tocLinks.forEach((t) => t.classList.remove('active'))
                const active = tocLinks.find((t) => t.dataset.heading === entry.target.id)
                active?.classList.add('active')
              }
            })
          },
          { rootMargin: '-80px 0px -75% 0px' },
        )
        tocLinks.forEach((t) => {
          const el = document.getElementById(t.dataset.heading || '')
          if (el) observer.observe(el)
        })
      })()

      // Search → delegated to SearchDialog.astro (window._sageSearch)
    </script>
  </body>
</html>
