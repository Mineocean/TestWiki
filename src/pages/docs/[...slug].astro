---
import DocsLayout from '../../layouts/DocsLayout.astro'
import topMeta from '../../content/docs/_meta'

interface MdxFrontmatter {
  title: string
  description?: string
}

interface MdxModule {
  frontmatter: MdxFrontmatter
  default: any
  getHeadings: () => { depth: number; slug: string; text: string }[]
}

export async function getStaticPaths() {
  const docs = import.meta.glob('../../content/docs/**/*.mdx')
  return Object.keys(docs).map((filePath) => {
    const slug = filePath.replace('../../content/docs/', '').replace('.mdx', '')
    return { params: { slug }, props: { slug } }
  })
}

const { slug } = Astro.props as { slug: string }

const modules = import.meta.glob<MdxModule>(
  '../../content/docs/**/*.mdx',
  { eager: true }
)

const filePath = `../../content/docs/${slug}.mdx`
const module = modules[filePath]
const title = module?.frontmatter?.title || slug.replace(/^.*\//, '')
const description = module?.frontmatter?.description
const headings = module?.getHeadings?.() || []
const Content = module?.default
---

<DocsLayout
  title={title}
  description={description}
  sidebar={topMeta}
  headings={headings}
>
  {Content && <Content />}
</DocsLayout>
