<!-- SearchDialog.astro — standalone search component -->
<div id="search-overlay"></div>
<div id="search-dialog">
  <div class="search-header">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    <input id="search-input" type="text" placeholder="搜索文档..." />
    <button class="search-close-btn" id="search-close" aria-label="关闭">&times;</button>
  </div>
  <div id="search-results" class="search-results"></div>
  <div class="search-empty-state" id="search-empty">未找到结果</div>
</div>

<script is:inline src="/pagefind/pagefind.js"></script>

<script>
  const searchOverlay = document.getElementById('search-overlay')
  const searchDialog = document.getElementById('search-dialog')
  const searchInput = document.getElementById('search-input')
  const searchResults = document.getElementById('search-results')
  const searchEmpty = document.getElementById('search-empty')

  function escapeHtml(str) {
    const div = document.createElement('div')
    div.textContent = str
    return div.innerHTML
  }

  function openSearch() {
    searchOverlay.style.display = 'block'
    searchDialog.classList.add('open-dialog')
    searchInput.focus()
    document.body.style.overflow = 'hidden'
  }

  function closeSearch() {
    searchOverlay.style.display = 'none'
    searchDialog.classList.remove('open-dialog')
    searchInput.value = ''
    searchResults.innerHTML = ''
    searchEmpty.style.display = 'none'
    document.body.style.overflow = ''
  }

  document.getElementById('search-close')?.addEventListener('click', closeSearch)
  searchOverlay?.addEventListener('click', closeSearch)

  document.addEventListener('keydown', (e) => {
    if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
      e.preventDefault()
      openSearch()
    }
    if (e.key === 'Escape') closeSearch()
  })

  window._sageSearch = { open: openSearch, close: closeSearch }

  let pagefindInstance = null

  searchInput.addEventListener('input', async function () {
    const query = this.value.trim()
    if (!query) {
      searchResults.innerHTML = ''
      searchEmpty.style.display = 'none'
      return
    }
    try {
      if (!pagefindInstance && typeof Pagefind !== 'undefined') {
        pagefindInstance = Pagefind
      }
      if (!pagefindInstance) {
        searchResults.innerHTML =
          '<div style="padding:2rem;text-align:center;color:var(--color-muted)">搜索组件加载中...</div>'
        return
      }
      const search = await pagefindInstance.search(query)
      if (!search || !search.results || search.results.length === 0) {
        searchResults.innerHTML = ''
        searchEmpty.style.display = 'block'
        return
      }
      searchEmpty.style.display = 'none'
      const results = await Promise.all(search.results.slice(0, 8).map((r) => r.data()))
      searchResults.innerHTML = results
        .map(
          (r) => `
        <a href="${escapeHtml((r.url || '').replace(/\.html$/, '').replace(/\/index$/, ''))}" class="search-result-item">
          <div class="search-result-title">${escapeHtml(r.meta.title || '')}</div>
          <div class="search-result-excerpt">${escapeHtml(r.excerpt || '')}</div>
        </a>
      `,
        )
        .join('')
    } catch (e) {
      console.warn('Search error:', e)
    }
  })
</script>
