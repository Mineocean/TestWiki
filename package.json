{
  "name": "sage",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist && npx staticrypt dist/docs/dev/secret/index.html -p sage123 -d dist/docs/dev/secret/ --short -t src/staticrypt-template.html",
    "encrypt": "staticrypt dist/docs/dev/secret/index.html -p sage123 -d dist/docs/dev/secret/ --short",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "astro": "^6.2.2",
    "pagefind": "^1.5.2",
    "staticrypt": "^3.5.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
